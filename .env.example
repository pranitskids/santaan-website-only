# Core site identity
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# Optional legacy auth values; not required for the public website-only deploy.
NEXTAUTH_URL=https://your-site.netlify.app
NEXTAUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_URL=https://your-site.netlify.app
BETTER_AUTH_SECRET=replace_with_a_long_random_secret

# Optional Medium cache database. Leave blank to read the Medium feed directly.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Analytics / tags
NEXT_PUBLIC_GTM_ID=GTM-P45XTFCS
GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
META_PIXEL_ID=
NEXT_PUBLIC_WEBSITE_INTENT_URL=/api/website/intent
WEBSITE_INTENT_API_URL=https://api.crmai.greybrain.ai/api/website/intent
WEBSITE_INTENT_ORIGIN=https://www.santaan.in
WEBSITE_INTENT_API_TOKEN=

# Medium content pipeline. Optional unless RSS2JSON rate limits the public feed.
RSS2JSON_API_KEY=

# AICRM webhook handoff
AICRM_LEAD_WEBHOOK_URL=
AICRM_LEAD_WEBHOOK_TOKEN=

# Practo booking UI
NEXT_PUBLIC_PRACTO_WIDGET_ID=
NEXT_PUBLIC_PRACTO_BOOKING_URL=
NEXT_PUBLIC_PRACTO_DOCTOR_LABEL=
NEXT_PUBLIC_PRACTO_LOCATION_LABEL=
