{
  "name": "santaan-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "assets:check": "node src/scripts/check-public-assets.mjs",
    "assets:check:strict": "node src/scripts/check-public-assets.mjs --strict",
    "crm:health": "node --import tsx src/scripts/check-crm-health.ts",
    "crm:health:prod": "unset NODE; vercel env pull /tmp/santaan_prod_crm_health --environment production --yes && node --import tsx src/scripts/check-crm-health.ts --dotenv-file=/tmp/santaan_prod_crm_health",
    "integrations:check": "node src/scripts/check-integrations.mjs",
    "integrations:check:prod": "unset NODE; vercel env pull /tmp/santaan_prod_env_check --environment production --yes && node src/scripts/check-integrations.mjs --env-file=/tmp/santaan_prod_env_check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:migrate": "node --import tsx src/scripts/migrate.ts",
    "db:migrate:prod": "node --import tsx src/scripts/migrate-prod.ts",
    "migrate:blogs": "node --import tsx src/scripts/migrate-blog-posts.ts",
    "migrate:spend": "node src/scripts/migrate-spend.mjs",
    "migrate:ops-inputs": "node src/scripts/migrate-ops-inputs.mjs",
    "migrate:ops-workboard": "node src/scripts/migrate-ops-workboard.mjs",
    "migrate:neodove-sync": "node src/scripts/migrate-neodove-deep-sync.mjs",
    "migrate:voice-ai": "node src/scripts/migrate-voice-ai.mjs",
    "seed:voice-ops": "node src/scripts/seed-voice-ops-settings.mjs",
    "voice:bolna:verify": "node src/scripts/setup-bolna-inbound.mjs",
    "voice:bolna:setup": "node src/scripts/setup-bolna-inbound.mjs --apply",
    "voice:azure:speech": "node src/scripts/azure-speech-spike.mjs",
    "voice:edesy:call": "node src/scripts/trigger-edesy-outbound.mjs",
    "migrate:meta-launch": "node src/scripts/migrate-meta-launch-drafts.mjs",
    "migrate:meta-conversions": "node src/scripts/migrate-meta-conversion-events.mjs",
    "migrate:meta-audiences": "node src/scripts/migrate-meta-audiences.mjs",
    "seed:ceo-week1-kpis": "node --import tsx src/scripts/seed-ceo-week1-kpis.ts",
    "test:content-draft": "node --import tsx src/scripts/test-content-draft.ts"
  },
  "dependencies": {
    "@better-auth/infra": "^0.1.13",
    "@libsql/client": "^0.17.0",
    "@netlify/functions": "^4.2.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.30.0",
    "groq-sdk": "^0.37.0",
    "lenis": "^1.3.17",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
